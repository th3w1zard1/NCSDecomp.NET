<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <LangVersion>7.3</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <GenerateGlobalUsings>false</GenerateGlobalUsings>
    <!--
      AllowUnsafeBlocks is required for Net472Polyfills.cs, which uses pointer-based
      type-punning (*(float*)&value) to implement BitConverter polyfills absent in
      .NET Framework 4.7.2. This is the ONLY file in the project that uses unsafe code.
      Before adding any new unsafe code, obtain explicit review approval and document
      the rationale here.
    -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>BioWare</AssemblyName>
    <RootNamespace>BioWare</RootNamespace>
    <OutputType>Library</OutputType>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <Optimize>false</Optimize>
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <RunAnalyzersDuringBuild>false</RunAnalyzersDuringBuild>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
    <Deterministic>true</Deterministic>
    <RunAnalyzersDuringBuild>false</RunAnalyzersDuringBuild>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <WarningLevel>0</WarningLevel>
  </PropertyGroup>

  <!-- NuGet Package Metadata -->
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>BioWare.NET</PackageId>
    <Version>1.0.0</Version>
    <Authors>OldRepublicDevs</Authors>
    <Description>BioWare file format library for .NET. Reads and writes KOTOR/TSL game file formats (GFF, TLK, 2DA, NCS, ERF, RIM, TPC, MDL, LYT, VIS, SSF, LIP, BWM, etc.). Includes NCS script decompiler and TSLPatcher engine.</Description>
    <PackageTags>bioware;kotor;tsl;ncs;gff;2da;tlk;nwscript;decompiler;modding</PackageTags>
    <PackageLicenseExpression>BSL-1.1</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/th3w1zard1/BioWare.NET</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SharpCompress" Version="0.44.5" />
    <PackageReference Include="ini-parser-netstandard" Version="2.5.3" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.2" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="JetBrains.Annotations" Version="2025.2.4" />
    <PackageReference Include="System.CommandLine" Version="2.0.2" />
    <PackageReference Include="System.Text.Encoding.CodePages" Version="8.0.0" />
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
    <PackageReference Include="System.Threading.Tasks.Dataflow" Version="8.0.1" />
    <PackageReference Include="System.Drawing.Common" Version="8.0.10" />
    <PackageReference Include="System.Text.RegularExpressions" Version="4.3.1" />
    <PackageReference Include="System.Threading.Tasks.Extensions" Version="4.6.3" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Net472Polyfills.cs" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resource\Formats\NCS\Decomp\lexer.dat">
      <LogicalName>BioWare.Resource.Formats.NCS.Decomp.lexer.dat</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Resource\Formats\NCS\Decomp\parser.dat">
      <LogicalName>BioWare.Resource.Formats.NCS.Decomp.parser.dat</LogicalName>
    </EmbeddedResource>
  </ItemGroup>
</Project>
